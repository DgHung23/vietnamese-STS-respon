# This app uses Application Default Credentials from gcloud.
# Run this once if your local credentials are not already configured:
# gcloud auth application-default login
#
# Optional:
# gcloud config set project YOUR_PROJECT_ID

STT_LANGUAGE_CODE=vi-VN
STT_MODEL=latest_long
STT_SAMPLE_RATE=16000

# Gemini API key. Copy this file to .env, then replace the placeholder.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# RAG FAQ configuration.
FAQ_PATH=faq.csv
RAG_THRESHOLD=0.72

# FPT.AI Text-to-Speech configuration.
FPT_API_KEY=YOUR_FPT_AI_API_KEY
FPT_TTS_VOICE=banmai
FPT_TTS_SPEED=1
FPT_TTS_POLL_DELAY=2
FPT_TTS_MAX_WAIT=30

# Optional microphone index from:
# python stt.py --list-devices
# STT_DEVICE_INDEX=3
